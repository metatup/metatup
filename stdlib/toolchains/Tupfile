function host {
  ifeq (@(TUP_PLATFORM),win32)
    fbind { }: vals := call msvc({ ..., })
  endif

  ifeq (@(TUP_PLATFORM),macosx)
    fbind { }: vals := call clang({
      ...,
      "toolchain/os": "macos"
    })
  endif

  ifeq (@(TUP_PLATFORM),linux)
    fbind { }: vals := call gcc({
      ...,
      "toolchain/os": "linux"
    })
  endif

  return {
    ...vals
  }
}

function gcc {
  bind os := "toolchain/os" || linux

  return {
    overriding "toolchain/family": "gcc",
    overriding "toolchain/os": "$(os)",
    overriding "toolchain/cc": "gcc",
    overriding "toolchain/cxx": "g++",
    overriding "toolchain/linker": "g++",
    overriding "toolchain/ar": "ar"
  }
}

function clang {
  bind os := "toolchain/os" || linux

  return {
    overriding "toolchain/family": "clang",
    overriding "toolchain/os": "$(os)",
    overriding "toolchain/cc": "clang",
    overriding "toolchain/cxx": "clang++",
    overriding "toolchain/linker": "clang++",
    overriding "toolchain/ar": "ar"
  }
}

function msvc {
  return {
    overriding "toolchain/family": "msvc",
    overriding "toolchain/os": "windows",
    overriding "toolchain/cc": "cl",
    overriding "toolchain/cxx": "cl",
    overriding "toolchain/linker": "link",
    overriding "toolchain/ar": "lib"
  }
}

function package_flags {
  bind family := "toolchain/family" || 
  bind include_dir := "package/include_dir" || 
  bind lib_dir := "package/lib_dir" || 
  bind posix_link_flags := "package/posix_link_flags" || 
  bind msvc_link_flags := "package/msvc_link_flags" || 
  FAMILY = $(family)
  INCLUDE_DIR = $(include_dir)
  LIB_DIR = $(lib_dir)
  POSIX_LINK_FLAGS = $(posix_link_flags)
  MSVC_LINK_FLAGS = $(msvc_link_flags)

  ifeq ($(FAMILY),)
    ifeq (@(TUP_PLATFORM),win32)
      FAMILY = msvc
    else
      FAMILY = gcc
    endif
  endif

  ifeq ($(FAMILY),msvc)
    CFLAGS =
    LDFLAGS =
    ifneq ($(INCLUDE_DIR),)
      CFLAGS = /I$(INCLUDE_DIR)
    endif
    ifneq ($(LIB_DIR),)
      LDFLAGS = /LIBPATH:$(LIB_DIR)
    endif
    ifneq ($(MSVC_LINK_FLAGS),)
      LDFLAGS = $(LDFLAGS) $(MSVC_LINK_FLAGS)
    endif
    return {
      appending "flags/c": "$(CFLAGS)",
      appending "flags/ld_exe": "$(LDFLAGS)"
    }
  endif

  CFLAGS = 
  LDFLAGS =
  ifneq ($(INCLUDE_DIR),)
    CFLAGS = -I$(INCLUDE_DIR)
  endif
  ifneq ($(LIB_DIR),)
    LDFLAGS = -L$(LIB_DIR)
  endif
  ifneq ($(POSIX_LINK_FLAGS),)
    LDFLAGS = $(LDFLAGS) $(POSIX_LINK_FLAGS)
  endif

  return {
    appending "flags/c": "$(CFLAGS)",
    appending "flags/ld_exe": "$(LDFLAGS)"
  }
}
